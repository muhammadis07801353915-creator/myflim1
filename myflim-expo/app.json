{
  "expo": {
    "name": "My Flim+",
    "slug": "myflim-mobile",
    "scheme": "myflim",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon_backup.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-screen-full.png",
      "resizeMode": "cover",
      "backgroundColor": "#0F0F13"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.muhamad.myflim",
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon_backup.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser"
    ],
    "owner": "myflim2",
    "extra": {
      "eas": {
        "projectId": "ae5cc4b6-0fb3-43a0-bcbc-914656b40aa9"
      }
    }
  }
}
