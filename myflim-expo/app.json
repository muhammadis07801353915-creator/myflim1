{
  "expo": {
    "name": "My Flim+",
    "slug": "myflim-mobile",
    "scheme": "myflim",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-screen-full.jpg",
      "resizeMode": "cover",
      "backgroundColor": "#0F0F13"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.muhamad.myflim",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "268a3489-8283-4d38-a863-52304e07fab8"
      }
    },
    "owner": "muhamad1"
  }
}
